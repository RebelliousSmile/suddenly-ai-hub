{"id":"567e5b6c-3845-4f51-af47-71ff8457c53c","level":"fragment","tags":{"univers":["medieval_fantastique"],"situation":["combat"],"rapport_initial":["hostile"],"voix":["solennel"],"emotion_dominante":["colere"]},"content":{"text":"L'air sent la terre humide et des fleurs inconnues.*\n\n\"Ce n'est pas une grotte\", me dis-je.","char_pov":"neutral"},"user_id":null,"instance_id":null,"created_at":"2026-05-17T05:47:10.273617Z","source":"bootstrap","signature":null,"quality_score":null,"archived_at":null}
