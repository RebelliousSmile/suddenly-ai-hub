# Suddenly Muses — variables d'environnement
# Copier en .env et adapter avant de lancer le service.

# ---------------------------------------------------------------------------
# Chemins de persistance
# ---------------------------------------------------------------------------

# Répertoire contenant les fichiers JSONL des tables servies par le service.
# Chaque sous-dossier correspond à une cellule contextuelle.
MUSES_TABLE_DIR=tables/bootstrap_cell_medfan_combat_hostile_solennel_colere

# Répertoire des stores feedback (trust, profil de style, online learner,
# event log). Sera créé si absent.
MUSES_FEEDBACK_DIR=feedback

# Répertoire des snapshots horodatés (rollback). Sera créé si absent.
MUSES_SNAPSHOT_DIR=snapshots

# ---------------------------------------------------------------------------
# Authentification
# ---------------------------------------------------------------------------

# Token requis pour les endpoints /v1/admin/* (header X-Admin-Token).
# Si vide, le service refuse de démarrer sauf si MUSES_BIND_HOST=127.0.0.1.
MUSES_ADMIN_TOKEN=

# Mode de vérification ActivityPub des requêtes entrantes.
#   stub  — parse uniquement le header Signature, pas de crypto (dev seul)
#   strict — vérif RSA-SHA256 + fetch actor + anti-replay (production)
MUSES_SIGNATURE_MODE=stub

# Fenêtre anti-replay (secondes) — rejette les requêtes dont l'en-tête Date
# est plus ancien que cette valeur. Ignoré si MUSES_SIGNATURE_MODE=stub.
MUSES_SIGNATURE_MAX_AGE_SECONDS=300

# ---------------------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------------------

# Encodeur d'embeddings utilisé en production.
#   stub               — déterministe, sans dépendance (dev/tests)
#   sentence_transformer — modèle CPU multilingue (production)
MUSES_ENCODER=sentence_transformer

# Nom du modèle sentence-transformers (ignoré si MUSES_ENCODER=stub).
MUSES_ENCODER_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Dimension du stub encoder (ignoré si MUSES_ENCODER=sentence_transformer).
MUSES_STUB_ENCODER_DIM=16

# ---------------------------------------------------------------------------
# Service HTTP
# ---------------------------------------------------------------------------

MUSES_BIND_HOST=127.0.0.1
MUSES_BIND_PORT=8000

# Rate limit par IP (requêtes / minute). 0 = désactivé.
MUSES_RATE_LIMIT_PER_MINUTE=60

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Niveau de log : DEBUG, INFO, WARNING, ERROR
MUSES_LOG_LEVEL=INFO

# Format : json (production) ou text (dev)
MUSES_LOG_FORMAT=text
